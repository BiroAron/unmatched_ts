{
  "compilerOptions": {
    /* 1. The "Extension Fix" Settings */
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true, // Required when using .ts extensions in imports

    /* 2. File Layout */
    "rootDir": "./src",
    "types": ["node"],
    "lib": ["esnext"],

    /* 3. Your Strict Rules (Keep these!) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
